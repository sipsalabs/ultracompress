# ============================================================
# UltraCompress — .gitignore
# ============================================================

# ----- Python -----
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# ----- Model weights & data (too large for git) -----
*.pt
*.safetensors
*.gguf
*.bin
*.ucz
*.uc

# ----- v3 packed customer artifacts (uploaded to HF, not in git) -----
_packed_*_v3/
_packed_*_v2/
_uc_*/

# ----- Local IDE / operator state (never push) -----
.serena/
.cursor/
.aider*
.aeon/
CLAUDE.md
README.v3.draft.md
docs/IN_FLIGHT.md
docs/MORNING_SUMMARY_*.md
docs/SIP_SEND_CHECKLIST_*.md
docs/OPERATOR_PLAYBOOK_*.md

# ----- Checkpoints -----
checkpoints*/

# ----- Logs & results (regeneratable) -----
logs/
*.log
*.err
*_results.json
*_results.pt

# ----- IDE & editors -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Misc -----
.claude/
.playwright-mcp/
full_chat_transcript.jsonl
2???-??-??-*.txt
plots/

# Packed Claim-16 binaries (multi-GB, regeneratable via pack_all_v17.py)
v17_*.bin

# Wave-45 operational flags (generated by wave45_finisher.py)
wave45_ready.flag
wave45_FAILED.flag

wave46_ready.flag
wave46_FAILED.flag

wave47_ready.flag
wave47_FAILED.flag

wave48_ready.flag
wave48_FAILED.flag
