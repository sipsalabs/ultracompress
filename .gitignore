# ============================================================
# UltraCompress — .gitignore
# ============================================================

# ----- Python -----
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# ----- Model weights & data (too large for git) -----
*.pt
*.safetensors
*.gguf
*.bin
*.ucz

# ----- Checkpoints -----
checkpoints*/

# ----- Logs & results (regeneratable) -----
logs/
*.log
*.err
*_results.json
*_results.pt

# ----- IDE & editors -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Misc -----
.claude/
.playwright-mcp/
full_chat_transcript.jsonl
2???-??-??-*.txt
plots/

# Packed Claim-16 binaries (multi-GB, regeneratable via pack_all_v17.py)
v17_*.bin

# Wave-45 operational flags (generated by wave45_finisher.py)
wave45_ready.flag
wave45_FAILED.flag

wave46_ready.flag
wave46_FAILED.flag

wave47_ready.flag
wave47_FAILED.flag

wave48_ready.flag
wave48_FAILED.flag
