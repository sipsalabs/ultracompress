# ============================================================
# UltraCompress — .gitignore
# ============================================================

# ----- Python -----
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.mypy_cache/
.pytest_cache/

# ----- Model weights & data (too large for git) -----
*.pt
*.safetensors
*.gguf
*.bin
*.ucz

# ----- Checkpoints -----
checkpoints*/

# ----- Logs & results (regeneratable) -----
logs/
*.log
*.err
*_results.json
*_results.pt

# ----- IDE & editors -----
.vscode/
.idea/
*.swp
*.swo

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Misc -----
.claude/
.playwright-mcp/
full_chat_transcript.jsonl
plots/

v17_qwen3_1.7b.bin
