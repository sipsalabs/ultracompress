include README.md
include NOTICE.md
include LICENSE
include LICENSE.apache
include PATENT_NOTICE.md
include pyproject.toml
recursive-include ultracompress *.py
recursive-include lib *.py
prune tests
prune docs
prune scripts
prune tools
prune deploy
prune experiments
prune archive
prune .github
prune .git
prune build
prune dist
prune _packed_*
prune _hf_readme_refresh
prune _existing_readmes
prune _org_README_2026_05_08
exclude .env
exclude .pypi_tokens_found.txt
exclude *.log
exclude CLAUDE.md
exclude README.previous.md
exclude README.OLD_PRE_CATCH12.md
exclude README.v3.draft.md
exclude REPRODUCE.md
exclude RESULTS.md
exclude PATENT_CLAIMS.md
exclude *.pt
exclude *.safetensors
exclude *.bin
exclude *.gguf
exclude *.uc
exclude *.ucz
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
