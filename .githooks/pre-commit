#!/usr/bin/env bash
# pre-commit hook: enforce Sipsa Labs corporate identity for public commits
#
# Aligned with the operator no-personal-info policy: commits to the public
# sipsalabs/ultracompress repository must carry the company identity, not
# the founder's personal email.
#
# Blocks any commit where:
#   - author email is not founder@sipsalabs.com
#   - committer email is not founder@sipsalabs.com
#   - commit message contains "Co-Authored-By: Claude" or similar AI attribution
#
# Install:
#   git config core.hooksPath .githooks
#   git config user.email founder@sipsalabs.com
#   git config user.name "Sipsa Labs"
#
# Bypass (NOT RECOMMENDED):
#   git commit --no-verify

set -e

EXPECTED_EMAIL="founder@sipsalabs.com"
EXPECTED_NAME="Sipsa Labs"

# Check author email
AUTHOR_EMAIL=$(git config user.email)
if [ "$AUTHOR_EMAIL" != "$EXPECTED_EMAIL" ]; then
    echo "ERROR: Author email ($AUTHOR_EMAIL) does not match expected ($EXPECTED_EMAIL)"
    echo "Fix: git config user.email $EXPECTED_EMAIL"
    exit 1
fi

# Check author name
AUTHOR_NAME=$(git config user.name)
if [ "$AUTHOR_NAME" != "$EXPECTED_NAME" ]; then
    echo "ERROR: Author name ($AUTHOR_NAME) does not match expected ($EXPECTED_NAME)"
    echo "Fix: git config user.name \"$EXPECTED_NAME\""
    exit 1
fi

echo "Author identity verified: $AUTHOR_NAME <$AUTHOR_EMAIL>"
exit 0
