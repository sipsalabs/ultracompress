#!/usr/bin/env bash
# commit-msg hook: reject any commit message mentioning AI co-authorship
#
# Blocks commit messages that contain:
#   - "Co-Authored-By: Claude"
#   - "Co-Authored-By: Copilot"
#   - "Generated with Claude Code"
#   - "Generated by Claude"
#   - Any "Co-Authored-By" trailer with an AI-looking attribution
#
# This is the second-line defense after the author-identity pre-commit check.

COMMIT_MSG_FILE="$1"

if [ -z "$COMMIT_MSG_FILE" ]; then
    exit 0
fi

if grep -Eqi "Co-Authored-By:.*(Claude|Copilot|GPT-|Anthropic|OpenAI|ChatGPT|Cursor|Aider|Windsurf)" "$COMMIT_MSG_FILE"; then
    echo "ERROR: Commit message contains AI co-authorship trailer."
    echo ""
    echo "Offending lines:"
    grep -Ei "Co-Authored-By:.*(Claude|Copilot|GPT-|Anthropic|OpenAI|ChatGPT|Cursor|Aider|Windsurf)" "$COMMIT_MSG_FILE"
    echo ""
    echo "This repo requires single-inventor attribution for patent-defense purposes."
    echo "Remove the Co-Authored-By line and retry."
    exit 1
fi

if grep -Eqi "Generated (with|by) Claude|Generated (with|by) Copilot" "$COMMIT_MSG_FILE"; then
    echo "ERROR: Commit message says 'Generated with Claude/Copilot' which implies AI authorship."
    echo "Rephrase to describe what the commit does, not how you wrote it."
    exit 1
fi

exit 0
